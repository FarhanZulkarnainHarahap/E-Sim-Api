// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
enum PlanCategory {
  LIMITED
  UNLIMITED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

enum Role {
  ADMIN
  USER
}
model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  role        Role     @default(USER)
  passwordHash String
  cartItems    CartItem[]
  orders       Order[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Country {
  id              String   @id @default(uuid())
  name            String
  slug            String          @unique
  flagUrl         String
  cartItems       CartItem[]
  regionCountries RegionCountry[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Region {
  id              String          @id @default(uuid())
  name            String
  slug            String          @unique
  icon            String?
  regionCountries RegionCountry[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model RegionCountry {
  id        String @id @default(uuid())
  regionId  String
  countryId String

  region  Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([regionId, countryId])
  @@index([regionId])
  @@index([countryId])
}

model Plan {
  id          String       @id @default(uuid())
  title       String
  sublabel    String?
  priceIdr    Int
  category    PlanCategory
  durationTab String
  sortOrder   Int
  cartItems   CartItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}
model CartItem {
  id             String   @id @default(uuid())
  quantity       Int
  activationDate DateTime?
  unitPriceIdr   Int
  totalPriceIdr  Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId    String
  countryId String
  planId    String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id])
  plan    Plan    @relation(fields: [planId], references: [id])
}

model Order {
  id             String      @id @default(uuid())
  userId         String
  status         OrderStatus @default(PENDING)
  totalAmountIdr Int
  paymentRef     String?
  items          OrderItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OrderItem {
  id             String   @id @default(uuid())
  orderId        String
  countryName    String
  countrySlug    String
  countryFlag    String
  planTitle      String
  planSublabel   String?
  quantity       Int
  activationDate DateTime?
  unitPriceIdr   Int
  totalPriceIdr  Int
  createdAt      DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}